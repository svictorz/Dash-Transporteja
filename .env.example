# Supabase (obrigatório) – use o mesmo projeto para dashboard e app motorista (JaAPP)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anonima-aqui

# Opcional: script create-admin-user.mjs (cria usuário admin)
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (nunca exponha no frontend)

# Cotação por rota (/dashboard/cotacao) — atualize o diesel com a média semanal da ANP
# COTACAO_DIESEL_PRECO_LITRO=6.35
# COTACAO_KM_POR_LITRO=3.2
# COTACAO_PEDAGIO_R_POR_KM=0.11
# COTACAO_NOMINATIM_USER_AGENT=SeuApp/1.0 (seu-email@dominio.com)
